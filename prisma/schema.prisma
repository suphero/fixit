generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Session {
  session_id    String    @id @default(auto()) @map("_id") @db.ObjectId
  id            String    @unique
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model Shop {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  shop                  String   @unique
  subscriptionId        String?
  subscriptionName      Subscription @default(Free)
  onboardingCompleted   Boolean  @default(false)
  onboardingCompletedAt DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Recommendation {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  shop                String
  targetType          TargetType
  productId           String?
  variantId           String?
  targetTitle         String
  targetUrl           String
  type                RecommendationType
  subTypes            RecommendationSubType[]
  status              RecommendationStatus @default(PENDING)
  premium             Boolean? @default(false)

  // Product Data Snapshot (for impact calculation without API calls)
  productSnapshot     Json?                   // Cached product/variant data for impact calculation

  // Impact Score fields
  impactScore         Float?   @default(0)    // Overall impact score (0-100)
  potentialRevenue    Float?   @default(0)    // Estimated revenue increase in shop currency
  impactType          String?  @default("neutral") // "positive" | "negative" | "neutral"
  impactMetadata      Json?                   // Additional metadata for impact calculation

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Add compound indexes for common query patterns
  @@index([shop, type, status])
  @@index([shop, targetType, status])
  @@index([shop, productId])
  @@index([shop, variantId])
  @@index([createdAt])
  @@index([shop, impactScore])
}

enum TargetType {
  PRODUCT
  PRODUCT_VARIANT
}

enum RecommendationType {
  PRICING
  TEXT
  MEDIA
  STOCK
}

enum RecommendationSubType {
  // Pricing related
  FREE
  CHEAP
  EXPENSIVE
  NO_COST
  SALE_AT_LOSS
  NO_DISCOUNT
  LOW_DISCOUNT
  HIGH_DISCOUNT

  // Text related
  SHORT_TITLE
  LONG_TITLE
  SHORT_DESCRIPTION
  LONG_DESCRIPTION

  // Media related
  NO_IMAGE

  // Stock related
  UNDERSTOCK
  OVERSTOCK
  NO_STOCK
  PASSIVE
}

enum RecommendationStatus {
  PENDING
  RESOLVED
}

// Sync with the Subscription enum in the Shopify app
enum Subscription {
  Free
  Premium
}

model Settings {
  id                      String   @id @default(auto()) @map("_id") @db.ObjectId
  shop                    String   @unique
  understockDays          Int      @default(7)
  overstockDays           Int      @default(60)
  minRevenueRate          Float    @default(10)
  maxRevenueRate          Float    @default(90)
  passiveDays             Int      @default(30)
  shortTitleLength        Int      @default(20)
  longTitleLength         Int      @default(70)
  shortDescriptionLength  Int      @default(80)
  longDescriptionLength   Int      @default(400)
  lowDiscountRate         Float    @default(5)
  highDiscountRate        Float    @default(70)
  lastReinitializeAt      DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model VariantMetric {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  shop              String
  variantId         String
  variantCreatedAt  DateTime
  lastOrderDate     DateTime?
  totalSold         Int      @default(0)
  averageDailySales Float    @default(0)
  lastCalculated    DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([shop, variantId])
  @@index([shop])
  @@index([variantId])
}
