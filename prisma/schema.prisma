generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Session {
  session_id    String    @id @default(auto()) @map("_id") @db.ObjectId
  id            String    @unique
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model Shop {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  shop              String   @unique
  subscriptionId    String?
  subscriptionName  Subscription @default(Free)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Recommendation {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  shop                String
  targetType          TargetType
  productId           String?
  variantId           String?
  targetTitle         String
  targetUrl           String
  type                RecommendationType
  subTypes            RecommendationSubType[]
  status              RecommendationStatus @default(PENDING)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Add compound indexes for common query patterns
  @@index([shop, type, status])
  @@index([shop, targetType, status])
  @@index([shop, productId])
  @@index([shop, variantId])
  @@index([createdAt])
}

enum TargetType {
  PRODUCT
  PRODUCT_VARIANT
}

enum RecommendationType {
  PRICING
  TEXT
  MEDIA
  STOCK
}

enum RecommendationSubType {
  // Pricing related
  FREE
  CHEAP
  EXPENSIVE
  NO_COST
  SALE_AT_LOSS
  NO_DISCOUNT
  LOW_DISCOUNT
  HIGH_DISCOUNT

  // Definition related
  SHORT_TITLE
  LONG_TITLE
  SHORT_DESCRIPTION
  LONG_DESCRIPTION
  NO_IMAGE

  // Stock related
  UNDERSTOCK
  OVERSTOCK
  NO_STOCK
  PASSIVE
}

enum RecommendationStatus {
  PENDING
  RESOLVED
}

// Sync with the Subscription enum in the Shopify app
enum Subscription {
  Free
  Premium
}

model Settings {
  id                      String   @id @default(auto()) @map("_id") @db.ObjectId
  shop                    String   @unique
  understockDays          Int      @default(7)
  overstockDays           Int      @default(60)
  minRevenueRate          Float    @default(0.1)
  maxRevenueRate          Float    @default(0.9)
  passiveDays             Int      @default(180)
  shortTitleLength        Int      @default(20)
  longTitleLength         Int      @default(70)
  shortDescriptionLength  Int      @default(80)
  longDescriptionLength   Int      @default(400)
  lowDiscountRate         Float    @default(0.05)
  highDiscountRate        Float    @default(0.7)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}
